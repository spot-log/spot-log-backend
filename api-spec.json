{
  "openapi": "3.0.3",
  "info": {
    "title": "SpotLog API",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Visibility": {
        "type": "string",
        "enum": ["PUBLIC", "PRIVATE"]
      },
      "MemoStatus": {
        "type": "string",
        "enum": ["ACTIVE", "EXPIRED"]
      },
      "TriggerRadius": {
        "type": "integer",
        "enum": [50, 100, 200, 500],
        "default": 100
      },
      "MemoResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "authorId": { "type": "string", "format": "uuid" },
          "visibility": { "$ref": "#/components/schemas/Visibility" },
          "status": { "$ref": "#/components/schemas/MemoStatus" },
          "title": { "type": "string", "nullable": true, "maxLength": 100 },
          "body": { "type": "string", "maxLength": 1000 },
          "placeName": { "type": "string", "nullable": true, "maxLength": 255 },
          "latitude": { "type": "number" },
          "longitude": { "type": "number" },
          "triggerRadius": { "$ref": "#/components/schemas/TriggerRadius" },
          "expiresAt": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "example": {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "authorId": "u1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "visibility": "PUBLIC",
          "status": "ACTIVE",
          "title": "가게 입구 안내",
          "body": "정문이 아니라 골목 안쪽 옆문으로 들어가세요. 정문은 잠겨있어요.",
          "placeName": "스타벅스 홍대점",
          "latitude": 37.5563,
          "longitude": 126.9236,
          "triggerRadius": 100,
          "expiresAt": "2026-05-10T00:00:00.000Z",
          "createdAt": "2026-04-10T10:00:00.000Z",
          "updatedAt": "2026-04-10T10:00:00.000Z"
        }
      },
      "MemoResponseWithDistance": {
        "allOf": [
          { "$ref": "#/components/schemas/MemoResponse" },
          {
            "type": "object",
            "properties": {
              "distanceMeters": {
                "type": "integer",
                "description": "현재 위치로부터의 거리(m). 좌표 제공 시에만 포함됨",
                "example": 243
              }
            }
          }
        ]
      },
      "CreateMemoBody": {
        "type": "object",
        "required": ["body", "visibility", "latitude", "longitude"],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 100,
            "description": "미입력 시 본문 앞 10자 자동 설정"
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "visibility": { "$ref": "#/components/schemas/Visibility" },
          "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
          "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
          "placeName": { "type": "string", "maxLength": 255 },
          "triggerRadius": { "$ref": "#/components/schemas/TriggerRadius" },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "PUBLIC 메모 전용. 미입력 시 30일 후 자동 설정"
          }
        },
        "example": {
          "title": "가게 입구 안내",
          "body": "정문이 아니라 골목 안쪽 옆문으로 들어가세요. 정문은 잠겨있어요.",
          "visibility": "PUBLIC",
          "latitude": 37.5563,
          "longitude": 126.9236,
          "placeName": "스타벅스 홍대점",
          "triggerRadius": 100,
          "expiresAt": "2026-05-10T00:00:00.000Z"
        }
      },
      "UpdateMemoBody": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "maxLength": 100 },
          "body": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "visibility": { "$ref": "#/components/schemas/Visibility" },
          "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
          "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
          "placeName": { "type": "string", "maxLength": 255 },
          "triggerRadius": { "$ref": "#/components/schemas/TriggerRadius" },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "PUBLIC 메모 전용"
          }
        },
        "example": {
          "body": "골목 안쪽 옆문으로 들어가세요. 계단 올라가면 바로 있어요.",
          "expiresAt": "2026-06-10T00:00:00.000Z"
        }
      },
      "RepublishBody": {
        "type": "object",
        "properties": {
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "미입력 시 30일 후 자동 설정"
          }
        },
        "example": {
          "expiresAt": "2026-07-10T00:00:00.000Z"
        }
      },
      "DeleteResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "deleted": { "type": "boolean" }
        },
        "example": {
          "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
          "deleted": true
        }
      },
      "GoogleCodeLoginBody": {
        "type": "object",
        "required": ["code", "redirectUri"],
        "properties": {
          "code": {
            "type": "string",
            "description": "Google authorization code received by the client"
          },
          "redirectUri": {
            "type": "string",
            "format": "uri",
            "description": "Redirect URI used when requesting the authorization code"
          },
          "codeVerifier": {
            "type": "string",
            "minLength": 43,
            "maxLength": 128,
            "description": "PKCE code verifier when the client uses PKCE"
          }
        },
        "example": {
          "code": "4/0AQSTgQExampleAuthCode",
          "redirectUri": "http://localhost:5173/auth/google/callback",
          "codeVerifier": "0123456789012345678901234567890123456789012"
        }
      },
      "AuthUserResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "email": { "type": "string", "format": "email" },
          "provider": { "type": "string", "enum": ["GOOGLE", "APPLE", "KAKAO"] },
          "nickname": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "OAuthLoginResponse": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" },
          "user": { "$ref": "#/components/schemas/AuthUserResponse" }
        },
        "example": {
          "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
          "user": {
            "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
            "email": "spotlog@example.com",
            "provider": "GOOGLE",
            "nickname": "SpotLog",
            "createdAt": "2026-04-24T00:00:00.000Z"
          }
        }
      }
    }
  },
  "paths": {
    "/auth/google/code": {
      "post": {
        "tags": ["Auth"],
        "summary": "Google authorization code login",
        "description": "Exchanges the client-provided Google authorization code on the server, loads the Google profile, creates or finds the user, and returns the service JWT.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GoogleCodeLoginBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JWT access token and authenticated user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OAuthLoginResponse" }
              }
            }
          },
          "400": { "description": "Invalid request body" },
          "401": { "description": "Invalid Google authorization code or Google account information" },
          "502": { "description": "Failed to exchange the code or load the Google profile from Google APIs" }
        }
      }
    },
    "/memos": {
      "post": {
        "tags": ["Memos"],
        "summary": "메모 작성",
        "description": "- 본문 1~1000자 필수\n- 제목 미입력 시 본문 앞 10자 자동 설정\n- PUBLIC 메모: expiresAt 미입력 시 30일 후 자동 만료\n- PRIVATE 메모: expiresAt 무시",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateMemoBody" },
              "examples": {
                "공개 메모": {
                  "value": {
                    "title": "가게 입구 안내",
                    "body": "정문이 아니라 골목 안쪽 옆문으로 들어가세요. 정문은 잠겨있어요.",
                    "visibility": "PUBLIC",
                    "latitude": 37.5563,
                    "longitude": 126.9236,
                    "placeName": "스타벅스 홍대점",
                    "triggerRadius": 100,
                    "expiresAt": "2026-05-10T00:00:00.000Z"
                  }
                },
                "개인 메모 (제목 없음)": {
                  "value": {
                    "body": "우유, 계란, 식빵, 두부",
                    "visibility": "PRIVATE",
                    "latitude": 37.5013,
                    "longitude": 127.0262,
                    "placeName": "이마트 역삼점",
                    "triggerRadius": 200
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "생성된 메모",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MemoResponse" }
              }
            }
          },
          "400": { "description": "유효하지 않은 입력값" },
          "401": { "description": "인증 필요" }
        }
      }
    },
    "/memos/me": {
      "get": {
        "tags": ["Memos"],
        "summary": "내 메모 목록 조회",
        "description": "- tab 미지정 시 전체 조회\n- sort=distance 사용 시 latitude, longitude 필수",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "tab",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["private", "public", "expired"]
            },
            "description": "개인/공개/만료됨 탭 필터"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["recent", "expiresSoon", "distance"],
              "default": "recent"
            }
          },
          {
            "name": "latitude",
            "in": "query",
            "schema": { "type": "number" },
            "description": "sort=distance 시 필수"
          },
          {
            "name": "longitude",
            "in": "query",
            "schema": { "type": "number" },
            "description": "sort=distance 시 필수"
          }
        ],
        "responses": {
          "200": {
            "description": "메모 목록",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/MemoResponseWithDistance" }
                }
              }
            }
          },
          "400": { "description": "sort=distance인데 좌표 미제공" },
          "401": { "description": "인증 필요" }
        }
      }
    },
    "/memos/nearby": {
      "get": {
        "tags": ["Memos"],
        "summary": "주변 공개 메모 탐색",
        "description": "- 기본 탐색 반경 500m\n- ACTIVE 상태의 PUBLIC 메모만 반환\n- 거리 가까운 순 정렬",
        "parameters": [
          {
            "name": "latitude",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "minimum": -90, "maximum": 90 },
            "example": 37.5563
          },
          {
            "name": "longitude",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "minimum": -180, "maximum": 180 },
            "example": 126.9236
          },
          {
            "name": "radius",
            "in": "query",
            "schema": { "type": "number", "default": 500 },
            "description": "탐색 반경(m)",
            "example": 500
          }
        ],
        "responses": {
          "200": {
            "description": "주변 공개 메모 목록 (거리순)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/MemoResponseWithDistance" }
                }
              }
            }
          },
          "400": { "description": "유효하지 않은 좌표" }
        }
      }
    },
    "/memos/{memoId}": {
      "get": {
        "tags": ["Memos"],
        "summary": "메모 상세 조회",
        "description": "본인 메모만 조회 가능. 만료 상태 자동 동기화",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "memoId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          }
        ],
        "responses": {
          "200": {
            "description": "메모 상세",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MemoResponse" }
              }
            }
          },
          "401": { "description": "인증 필요" },
          "404": { "description": "메모 없음 또는 권한 없음" }
        }
      },
      "patch": {
        "tags": ["Memos"],
        "summary": "메모 수정",
        "description": "- 본인 메모만 수정 가능\n- EXPIRED 상태 메모는 수정 불가 (재공개 이용)\n- PRIVATE으로 변경 시 expiresAt 자동 초기화\n- PUBLIC으로 변경 시 expiresAt 없으면 30일 기본값 설정",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "memoId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateMemoBody" },
              "example": {
                "body": "골목 안쪽 옆문으로 들어가세요. 계단 올라가면 바로 있어요.",
                "expiresAt": "2026-06-10T00:00:00.000Z"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "수정된 메모",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MemoResponse" }
              }
            }
          },
          "400": { "description": "유효하지 않은 입력값" },
          "401": { "description": "인증 필요" },
          "403": { "description": "만료된 메모 수정 불가" },
          "404": { "description": "메모 없음 또는 권한 없음" }
        }
      },
      "delete": {
        "tags": ["Memos"],
        "summary": "메모 삭제",
        "description": "본인이 작성한 메모만 삭제 가능",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "memoId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          }
        ],
        "responses": {
          "200": {
            "description": "삭제 완료",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeleteResponse" }
              }
            }
          },
          "401": { "description": "인증 필요" },
          "404": { "description": "메모 없음 또는 권한 없음" }
        }
      }
    },
    "/memos/{memoId}/republish": {
      "post": {
        "tags": ["Memos"],
        "summary": "만료된 공개 메모 재공개",
        "description": "- 만료된 공개 메모를 재공개\n- 내부적으로 새 메모 생성 (원본은 만료 상태로 유지)\n- expiresAt 미입력 시 30일 후 자동 설정",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "memoId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RepublishBody" },
              "example": {
                "expiresAt": "2026-07-10T00:00:00.000Z"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "재공개된 새 메모",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MemoResponse" }
              }
            }
          },
          "400": { "description": "만료된 메모가 아님 또는 공개 메모가 아님" },
          "401": { "description": "인증 필요" },
          "404": { "description": "메모 없음 또는 권한 없음" }
        }
      }
    }
  }
}
